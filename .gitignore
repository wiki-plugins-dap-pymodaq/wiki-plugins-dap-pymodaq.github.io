# ──────────────────────────────────────────────────────────────
# Dépendances (outillage de lint/format — non nécessaires au déploiement)
# ──────────────────────────────────────────────────────────────
node_modules/
.npm/
.pnpm-store/

# ──────────────────────────────────────────────────────────────
# Build / sorties générées (le site statique vit dans public/, versionné)
# ──────────────────────────────────────────────────────────────
dist/
build/
.cache/
*.min.css.map
*.min.js.map

# ──────────────────────────────────────────────────────────────
# Secrets et environnement — rien de sensible ne doit être commité
# ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ──────────────────────────────────────────────────────────────
# Logs et rapports
# ──────────────────────────────────────────────────────────────
*.log
npm-debug.log*
logs/
coverage/

# ──────────────────────────────────────────────────────────────
# Fichiers système d'exploitation
# ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ──────────────────────────────────────────────────────────────
# Outillage local de l'agent (non versionné)
# ──────────────────────────────────────────────────────────────
.claude/

# ──────────────────────────────────────────────────────────────
# Éditeurs / IDE
# ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.sublime-workspace
*.swp
*~
